/dts-v1/;

#include "bcm6368.dtsi"

/ {
	compatible = "comtrend,vr-3025u", "brcm,bcm6368";
	model = "Comtrend VR-3025u";

	aliases {
		led-boot = &power_green;
		led-dsl = &dsl_green;
		led-failsafe = &power_green;
		led-internet = &internet_green;
		led-running = &power_green;
		led-upgrade = &power_green;
	};

	chosen {
		bootargs = "console=ttyS0,115200 earlycon";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x04000000>;
	};

	keys {
		compatible = "gpio-keys-polled";
		#address-cells = <1>;
		#size-cells = <0>;
		poll-interval = <20>;

		reset {
			label = "reset";
			gpios = <&pinctrl 34 1>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};
	};

	leds {
		compatible = "gpio-leds";

		dsl_green: led@2 {
			label = "vr-3025u:green:dsl";
			gpios = <&pinctrl 2 1>;
		};

		internet_green: led@5 {
			label = "vr-3025u:green:internet";
			gpios = <&pinctrl 5 0>;
		};

		power_green: led@22 {
			label = "vr-3025u:green:power";
			gpios = <&pinctrl 22 0>;
			default-state = "on";
		};

		power_red: led@24 {
			label = "vr-3025u:red:power";
			gpios = <&pinctrl 24 0>;
		};

		internet_red: led@31 {
			label = "vr-3025u:red:internet";
			gpios = <&pinctrl 31 0>;
		};
	};

	bcm43222-sprom {
		compatible = "brcm,bcm43222-sprom";

		pci-bus = <0>;
		pci-dev = <1>;

		mtd-mac-address = <&cfe 0x6a0>;
		mtd-mac-address-increment = <1>;

		brcm,sprom-fixups = <97 0xfeb3>,
				    <98 0x1618>,
				    <99 0xfab0>,
				    <113 0xfed1>,
				    <114 0x1609>,
				    <115 0xfad9>;
	};
};

&ehci {
	status = "okay";
};

&ethernet {
	status = "okay";

	mtd-mac-address = <&cfe 0x6a0>;

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@0 {
			reg = <0>;
			label = "fe1";
			brcm,phy-id = <1>;
		};

		port@1 {
			reg = <1>;
			label = "fe2";
			brcm,phy-id = <2>;
		};

		port@2 {
			reg = <2>;
			label = "fe3";
			brcm,phy-id = <3>;
		};

		port@3 {
			reg = <3>;
			label = "fe4";
			brcm,phy-id = <4>;
		};
	};
};

&ohci {
	status = "okay";
};

&pci {
	status = "okay";
};

&pflash {
	status = "okay";

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		cfe: partition@0 {
			reg = <0x0000000 0x0200000>;
			label = "cfe";
			read-only;
		};

		partition@20000 {
			reg = <0x0020000 0x1fc0000>;
			label = "firmware";
			compatible = "brcm,bcm963xx-imagetag";
		};

		partition@1fe0000 {
			reg = <0x1fe0000 0x020000>;
			label = "nvram";
		};
	};
};

&pinctrl {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_ephy0_led &pinctrl_ephy1_led
		     &pinctrl_ephy2_led &pinctrl_ephy3_led>;
};

&uart0 {
	status = "okay";
};

&usbh {
	status = "okay";
};
